  "name": "ConfigStackMC",
  "description": "Configurable per-item max stack sizes for Minecraft ${minecraftVersion}.",
  "authors": ["ConfigStackMC"],
  "license": "All-Rights-Reserved",
  "environment": "*",
  "entrypoints": { "main": ["io.github.configstackmc.fabric.ConfigStackMcMod"] },
  "mixins": ["configstackmc.mixins.json"],
  "depends": {
    "fabricloader": ">=${fabricLoaderVersion}",
    "minecraft": "${minecraftVersion}",
    "java": ">=25",
    "fabric-api": ">=${fabricApiVersion}"
  }
}
